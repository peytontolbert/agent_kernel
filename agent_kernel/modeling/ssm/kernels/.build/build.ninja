ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-12.8/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=agent_kernel_selective_scan_cuda -DTORCH_API_INCLUDE_EXTENSION_H -isystem /home/peyton/miniconda3/envs/ai/lib/python3.11/site-packages/torch/include -isystem /home/peyton/miniconda3/envs/ai/lib/python3.11/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda-12.8/include -isystem /home/peyton/miniconda3/envs/ai/include/python3.11 -fPIC -std=c++17 -O3 -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=agent_kernel_selective_scan_cuda -DTORCH_API_INCLUDE_EXTENSION_H -isystem /home/peyton/miniconda3/envs/ai/lib/python3.11/site-packages/torch/include -isystem /home/peyton/miniconda3/envs/ai/lib/python3.11/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda-12.8/include -isystem /home/peyton/miniconda3/envs/ai/include/python3.11 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 --compiler-options '-fPIC' -O3 -std=c++17 --use_fast_math -lineinfo
cuda_post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/home/peyton/miniconda3/envs/ai/lib/python3.11/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda-12.8/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





rule link
  command = $cxx $in $ldflags -o $out

build selective_scan.o: compile /data/agentkernel/agent_kernel/modeling/ssm/kernels/src/selective_scan.cpp
build selective_scan_cuda.cuda.o: cuda_compile /data/agentkernel/agent_kernel/modeling/ssm/kernels/src/selective_scan_cuda.cu





build agent_kernel_selective_scan_cuda.so: link selective_scan.o selective_scan_cuda.cuda.o

default agent_kernel_selective_scan_cuda.so
